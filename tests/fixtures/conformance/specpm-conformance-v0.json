{
  "schemaVersion": 1,
  "suite": "specpm-conformance-v0",
  "cases": [
    {
      "id": "validate.valid_email_tools",
      "kind": "validate_package",
      "package": "examples/email_tools",
      "expected": {
        "status": "valid",
        "capabilities": [
          "document_conversion.email_to_markdown"
        ],
        "error_codes": [],
        "warning_codes": []
      }
    },
    {
      "id": "validate.missing_manifest",
      "kind": "validate_package",
      "package": "tests/fixtures/conformance/packages/missing_manifest",
      "expected": {
        "status": "invalid",
        "error_codes": [
          "manifest_missing"
        ]
      }
    },
    {
      "id": "validate.missing_referenced_spec",
      "kind": "validate_package",
      "package": "tests/fixtures/conformance/packages/missing_referenced_spec",
      "expected": {
        "status": "invalid",
        "error_codes": [
          "manifest_capability_not_declared",
          "spec_missing"
        ]
      }
    },
    {
      "id": "validate.spec_path_escape",
      "kind": "validate_package",
      "package": "tests/fixtures/conformance/packages/spec_path_escape",
      "expected": {
        "status": "invalid",
        "error_codes": [
          "manifest_capability_not_declared",
          "path_escape"
        ]
      }
    },
    {
      "id": "validate.manual_assertion_warning",
      "kind": "validate_package",
      "package": "tests/fixtures/conformance/packages/manual_assertion_warning",
      "expected": {
        "status": "warning_only",
        "warning_codes": [
          "manual_assertion_only_evidence"
        ]
      }
    },
    {
      "id": "validate.spec_authoring_quality_warning",
      "kind": "validate_package",
      "package": "tests/fixtures/conformance/packages/spec_authoring_quality_warning",
      "expected": {
        "status": "warning_only",
        "warning_codes": [
          "duplicate_boundary_document_id",
          "evidence_support_target_unknown",
          "unspecified_evidence_kind",
          "unspecified_effect_kind",
          "unspecified_interface_kind"
        ]
      }
    },
    {
      "id": "registry.yank_blocks_add_and_unyank_restores_add",
      "kind": "registry_lifecycle",
      "package": "examples/email_tools",
      "package_ref": "document_conversion.email_tools@0.1.0",
      "capability": "document_conversion.email_to_markdown",
      "yank_reason": "conformance lifecycle smoke",
      "expected": {
        "index_status": "indexed",
        "yank_status": "yanked",
        "search_yanked": true,
        "add_yanked_status": "invalid",
        "add_yanked_error_codes": [
          "package_yanked"
        ],
        "unyank_status": "unyanked",
        "add_unyanked_status": "added"
      }
    },
    {
      "id": "remote_registry.registry_status",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/registry-status.json",
      "expected": {
        "kind": "RemoteRegistryStatus",
        "status": "ok",
        "profile": "public_static_index",
        "package_count": 1,
        "version_count": 1
      }
    },
    {
      "id": "remote_registry.package_index",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/package-index.json",
      "expected": {
        "kind": "RemotePackageIndex",
        "status": "ok",
        "package_count": 1,
        "version_count": 1
      }
    },
    {
      "id": "remote_registry.package_metadata",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/package-metadata.json",
      "expected": {
        "kind": "RemotePackage",
        "status": "ok",
        "package_id": "document_conversion.email_tools"
      }
    },
    {
      "id": "remote_registry.package_version",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/package-version.json",
      "expected": {
        "kind": "RemotePackageVersion",
        "status": "ok",
        "package_id": "document_conversion.email_tools",
        "version": "0.1.0",
        "yanked": false
      }
    },
    {
      "id": "remote_registry.capability_search",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/capability-search.json",
      "expected": {
        "kind": "RemoteCapabilitySearch",
        "status": "ok",
        "capability_id": "document_conversion.email_to_markdown",
        "result_count": 1
      }
    },
    {
      "id": "remote_registry.yanked_version",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/yanked-version.json",
      "expected": {
        "kind": "RemotePackageVersion",
        "status": "ok",
        "package_id": "document_conversion.email_tools",
        "version": "0.1.0",
        "yanked": true
      }
    },
    {
      "id": "remote_registry.deprecated_version",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/deprecated-version.json",
      "expected": {
        "kind": "RemotePackageVersion",
        "status": "ok",
        "package_id": "document_conversion.email_tools",
        "version": "0.1.0",
        "yanked": false,
        "deprecated": true
      }
    },
    {
      "id": "remote_registry.error_not_found",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/error-not-found.json",
      "expected": {
        "kind": "RemoteRegistryError",
        "status": "not_found",
        "error_code": "package_not_found"
      }
    },
    {
      "id": "remote_registry.invalid_package_index_count",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/remote_registry/invalid-package-index-count.json",
      "expected": {
        "validation_status": "invalid",
        "validation_error_codes": [
          "remote_registry_field_invalid"
        ]
      }
    },
    {
      "id": "enterprise_registry.registry_status",
      "kind": "remote_registry_payload",
      "payload": "tests/fixtures/conformance/enterprise_registry/registry-status.json",
      "expected": {
        "kind": "RemoteRegistryStatus",
        "status": "ok",
        "profile": "enterprise_registry",
        "package_count": 0,
        "version_count": 0
      }
    },
    {
      "id": "public_registry.generated_email_tools_static_index",
      "kind": "public_registry_static_index",
      "package": "examples/email_tools",
      "registry": "https://registry.example.invalid",
      "expected": {
        "status": "ok",
        "archive": "v0/packages/document_conversion.email_tools/versions/0.1.0/document_conversion.email_tools-0.1.0.specpm.tgz",
        "version_endpoint": "v0/packages/document_conversion.email_tools/versions/0.1.0/index.json",
        "absent_paths": [
          "v0/packages/document_conversion.missing/index.json",
          "v0/capabilities/document_conversion.missing/packages/index.json"
        ],
        "endpoints": [
          {
            "path": "v0/status/index.json",
            "kind": "RemoteRegistryStatus",
            "status": "ok",
            "package_count": 1,
            "version_count": 1
          },
          {
            "path": "v0/packages/index.json",
            "kind": "RemotePackageIndex",
            "status": "ok",
            "package_count": 1,
            "version_count": 1
          },
          {
            "path": "v0/packages/document_conversion.email_tools/index.json",
            "kind": "RemotePackage",
            "status": "ok",
            "package_id": "document_conversion.email_tools"
          },
          {
            "path": "v0/packages/document_conversion.email_tools/versions/0.1.0/index.json",
            "kind": "RemotePackageVersion",
            "status": "ok",
            "package_id": "document_conversion.email_tools",
            "version": "0.1.0"
          },
          {
            "path": "v0/capabilities/document_conversion.email_to_markdown/packages/index.json",
            "kind": "RemoteCapabilitySearch",
            "status": "ok",
            "capability_id": "document_conversion.email_to_markdown",
            "result_count": 1
          }
        ]
      }
    }
  ]
}
